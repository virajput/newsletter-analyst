{
  "mcpServers": {
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "your-firecrawl_api_key"
      }
    },
    "docx-writer": {
      "command": "python",
      "args": ["tools/write_docx.py"],
      "env": {}
    }
  }
}